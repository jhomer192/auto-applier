# REQUIRED for the Telegram front-end (bot/main.py)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# REQUIRED for the Discord front-end (bot/main_discord.py) — the Telegram replacement.
# Run ONE front-end at a time (both poll the same inbox + DB; never run both).
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
JACK_USER_ID=
# Optional: comma/space-separated Discord user IDs of scoped applicants who may use
# ONLY /email (to register their own mailbox so the applier applies as them and reads
# their PINs). Everything else stays Jack-only. e.g. APPLICANT_USER_IDS=480439955408289822
APPLICANT_USER_IDS=

# REQUIRED — Claude auth (used for all AI analysis, resume generation, etc.).
# Pick ONE:
#   - Max/Pro subscription billing (what this deployment uses): set a long-lived
#     CLAUDE_CODE_OAUTH_TOKEN (from `claude setup-token`).
#   - API billing: set ANTHROPIC_API_KEY (https://console.anthropic.com/).
CLAUDE_CODE_OAUTH_TOKEN=
ANTHROPIC_API_KEY=

# REQUIRED when running under systemd as root: the Claude CLI refuses to run as
# root unless IS_SANDBOX=1, and needs a writable HOME. The systemd unit also sets
# these; included here so a hand-run `python -m bot.main_discord` works too.
IS_SANDBOX=1
HOME=/home/claude

# Optional — defaults shown
PROFILE_PATH=profile.yaml
DB_PATH=data/applications.db
LINKEDIN_AUTH_STATE=data/linkedin_auth.json
SCREENSHOT_DIR=data/screenshots

# Polling intervals in seconds (optional — defaults shown)
INBOX_POLL_INTERVAL=300
SEARCH_POLL_INTERVAL=1800
SOURCE_POLL_INTERVAL=3600

# GitHub token (optional) — enables GitHub Org discovery source.
# Without this, GitHub new-grad repos + company boards still run fine.
# Create a token at: https://github.com/settings/tokens (no scopes needed, public repos only)
GITHUB_TOKEN=

# Handshake (optional) — campus/new-grad job discovery.
# Requires a .edu or alumni Handshake account.
# Run: DISPLAY=:0 python setup/handshake_login.py
HANDSHAKE_AUTH_STATE=data/handshake_auth.json

# Apply-time email-PIN autonomy — the apply subprocess (scripts/check_email.cjs)
# reads the inbox directly to pull a job-application verification PIN mid-apply.
# This is the address on your applications (jack@homerfamily.com, a Network
# Solutions mailbox). Without IMAP_PASS the script exits and PIN autonomy is off.
IMAP_HOST=netsol-imap-oxcs.hostingplatform.com
IMAP_PORT=993
IMAP_USER=jack@homerfamily.com
IMAP_PASS=

# Gmail inbox (optional) — lets the bot notify you of recruiter replies and
# lets you respond directly from Telegram. Leave blank to disable.
# Use a Gmail App Password (not your account password):
# https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
