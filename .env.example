# REQUIRED — bot won't start without these
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# REQUIRED — Claude Code API key (used for all AI analysis, resume generation, etc.)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional — defaults shown
PROFILE_PATH=profile.yaml
DB_PATH=data/applications.db
LINKEDIN_AUTH_STATE=data/linkedin_auth.json
SCREENSHOT_DIR=data/screenshots

# Polling intervals in seconds (optional — defaults shown)
INBOX_POLL_INTERVAL=300
SEARCH_POLL_INTERVAL=1800
SOURCE_POLL_INTERVAL=3600

# GitHub token (optional) — enables GitHub Org discovery source.
# Without this, GitHub new-grad repos + company boards still run fine.
# Create a token at: https://github.com/settings/tokens (no scopes needed, public repos only)
GITHUB_TOKEN=

# Gmail inbox (optional) — lets the bot notify you of recruiter replies and
# lets you respond directly from Telegram. Leave blank to disable.
# Use a Gmail App Password (not your account password):
# https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
